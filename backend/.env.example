# LLM Configuration
LLM_API_KEY=your_api_key_here
LLM_MODEL=gemini-2.5-flash
LLM_TEMPERATURE=0.7

# API Configuration
CORS_ORIGINS=http://localhost:8501,http://127.0.0.1:8501

# Project Paths
DATA_PATH=./data
MODEL_PATH=./models/artifacts
LOG_PATH=./models/logs
CACHE_PATH=./models/cache

# Logging
LOG_LEVEL=INFO

# Random Seed
RANDOM_SEED=42

# Genetic Algorithm Parameters
GA_POPULATION_SIZE=20
GA_GENERATIONS=30
GA_MUTATION_RATE=0.15
GA_CROSSOVER_RATE=0.8

# Training Parameters
TEST_SIZE=0.3
STRATIFY_SPLIT=true
CV_FOLDS=5
